---
import "@/styles/global.css";
import WhatsAppFloat from "@/components/WhatsAppFloat.astro";
import CookieBanner from "@/components/CookieBanner.astro";


interface Props {
  title: string;
  description?: string;
  canonical?: string;
  noindex?: boolean;
}

const { title, description, canonical: canonicalProp, noindex = false } = Astro.props;
// Canonical automático — usa el prop si existe, sino construye desde la URL actual
const canonical = canonicalProp || `https://belgotours.com${currentUrl.replace(/\/$/, '')}${currentUrl.endsWith('/') ? '/' : ''}`;
const currentUrl = Astro.url.pathname;
const currentLang = currentUrl.split("/")[1] || "es";

/**
 * SOLO páginas de detalle de tour:
 * /es/tours/slug
 */
const isTourDetailPage = /^\/[a-z]{2}\/tours\/[^/]+\/?$/.test(currentUrl);

const languages = ["es", "en", "it", "fr", "pt"];

// Hreflang seguro — solo URLs reales
const hrefPath = currentUrl.replace(/^\/[a-z]{2}/, '').replace(/\/$/, '');
const isHomePage = hrefPath === '' || hrefPath === '/';
const isTourPath = hrefPath.startsWith('/tours/');
const isLegal = ['/privacy','/terms','/cookies','/legal-notice'].some(p => hrefPath.startsWith(p));
const TOUR_MAP: Record<string, Record<string, string>> = {
  '/tours/free-tour-bruselas':              {es:'/tours/free-tour-bruselas',en:'/tours/free-tour-brussels',it:'/tours/free-tour-bruxelles',fr:'/tours/tour-prive-bruxelles',pt:'/tours/free-tour-bruselas'},
  '/tours/free-tour-brujas':                {es:'/tours/free-tour-brujas',en:'/tours/free-tour-brussels',it:'/tours/free-tour-bruxelles',fr:'/tours/tour-prive-bruxelles',pt:'/tours/free-tour-brujas'},
  '/tours/tour-chocolate-cerveza-bruselas': {es:'/tours/tour-chocolate-cerveza-bruselas',en:'/tours/free-tour-brussels',it:'/tours/free-tour-bruxelles',fr:'/tours/tour-prive-bruxelles',pt:'/tours/tour-chocolate-cerveza-bruselas'},
  '/tours/tour-privado-bruselas':           {es:'/tours/tour-privado-bruselas',en:'/tours/private-tour-brussels',it:'/tours/tour-privato-bruxelles',fr:'/tours/tour-prive-bruxelles',pt:'/tours/tour-privado-bruselas'},
  '/tours/tour-privado-brujas':             {es:'/tours/tour-privado-brujas',en:'/tours/private-tour-brussels',it:'/tours/tour-privato-bruxelles',fr:'/tours/tour-prive-bruxelles',pt:'/tours/tour-privado-brujas'},
  '/tours/free-tour-brussels':              {es:'/tours/free-tour-bruselas',en:'/tours/free-tour-brussels',it:'/tours/free-tour-bruxelles',fr:'/tours/tour-prive-bruxelles',pt:'/tours/free-tour-brussels'},
  '/tours/private-tour-brussels':           {es:'/tours/tour-privado-bruselas',en:'/tours/private-tour-brussels',it:'/tours/tour-privato-bruxelles',fr:'/tours/tour-prive-bruxelles',pt:'/tours/private-tour-brussels'},
  '/tours/free-tour-bruxelles':             {es:'/tours/free-tour-bruselas',en:'/tours/free-tour-brussels',it:'/tours/free-tour-bruxelles',fr:'/tours/tour-prive-bruxelles',pt:'/tours/free-tour-bruxelles'},
  '/tours/tour-privato-bruxelles':          {es:'/tours/tour-privado-bruselas',en:'/tours/private-tour-brussels',it:'/tours/tour-privato-bruxelles',fr:'/tours/tour-prive-bruxelles',pt:'/tours/tour-privato-bruxelles'},
  '/tours/tour-prive-bruxelles':            {es:'/tours/tour-privado-bruselas',en:'/tours/private-tour-brussels',it:'/tours/tour-privato-bruxelles',fr:'/tours/tour-prive-bruxelles',pt:'/tours/tour-privado-bruselas'},
};
const slugMap = isTourPath ? (TOUR_MAP[hrefPath] ?? null) : null;
const hreflangLinks = languages.map(lang => {
  if (isHomePage) return {lang, href: `https://belgotours.com/${lang}/`};
  if (isTourPath && slugMap?.[lang]) return {lang, href: `https://belgotours.com/${lang}${slugMap[lang]}`};
  if (isLegal) return {lang, href: `https://belgotours.com/${lang}${hrefPath}`};
  return null;
}).filter((x): x is {lang: string; href: string} => x !== null);
---


<!DOCTYPE html>
<html lang={currentLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- FAVICONS -->
  <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="shortcut icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />

    <title>{title}</title>
    {description && <meta name="description" content={description} />}

    {canonical && <link rel="canonical" href={canonical} />}
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    {hreflangLinks.map(({lang, href}) => (
      <link rel="alternate" hreflang={lang} href={href} />
    ))}
    <link rel="alternate" hreflang="x-default" href="https://belgotours.com/en/" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`https://belgotours.com${currentUrl}`} />
    <meta property="og:image" content="https://belgotours.com/og-image.jpg" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Tipografía global (Inter) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <style>
      :root {
        --font-sans: Inter, system-ui, sans-serif;
        --bg-page: #f9fafb;
        --color-text: #0f172a;
        --color-muted: #6b7280;
        --color-primary: #0f172a;
        --color-secondary: #facc15;
        --color-card: #ffffff;
        --shadow-soft: 0 18px 45px rgba(15, 23, 42, 0.18);
      }
      body {
        margin: 0;
        font-family: var(--font-sans);
        background: var(--bg-page);
        color: var(--color-text);
      }
      
    </style>
  </head>

  <body>
  <!-- HEADER -->
  <slot name="header" />

  <!-- MAIN CONTENT -->
  <main>
    <slot />
  </main>

  <!-- COOKIE BANNER (GLOBAL) -->
  <CookieBanner lang={currentLang} />

  <!-- WHATSAPP FLOTANTE
       ❌ NO en /tours/*
       ✅ Sí en home, blog, info -->
  {!isTourDetailPage && (
    <WhatsAppFloat lang={currentLang} />
  )}
</body>

</html>
