---
export const prerender = false;
import Layout from "../../../layouts/Layout.astro";

const { lang } = Astro.params;
const token = Astro.url.searchParams.get("token");

if (!token) {
  return Astro.redirect(`/${lang}/`);
}

const texts: Record<string, any> = {
  es: {
    title: "¿Cómo fue tu experiencia?",
    subtitle: "Tu opinión ayuda a otros viajeros a elegir con confianza.",
    general: "Valoración general",
    details: "Detalles de la experiencia",
    professionalism: "Profesionalidad del guía",
    fun: "Diversión",
    communication: "Comunicación",
    quality: "Calidad de la información",
    route: "Ruta e itinerario",
    publicCommentTitle: "Cuéntanos tu experiencia",
    publicCommentPlaceholder: "¿Qué fue lo que más disfrutaste? (mínimo 20 caracteres)",
    minCharacters: "Mínimo 20 caracteres.",
    submitReview: "Enviar reseña",
    reviewVisibility: "Tu reseña aparecerá públicamente tras ser revisada.",
    ratingLabels: { 1: "Podemos mejorar", 2: "Buena experiencia", 3: "Muy buena experiencia", 4: "Excelente experiencia", 5: "Experiencia inolvidable" },
  },
  en: {
    title: "How was your experience?",
    subtitle: "Your review helps other travelers choose with confidence.",
    general: "Overall rating",
    details: "Experience details",
    professionalism: "Guide professionalism",
    fun: "Fun factor",
    communication: "Communication",
    quality: "Quality of information",
    route: "Route & itinerary",
    publicCommentTitle: "Tell us about your experience",
    publicCommentPlaceholder: "What did you enjoy most? (minimum 20 characters)",
    minCharacters: "Minimum 20 characters.",
    submitReview: "Submit review",
    reviewVisibility: "Your review may appear publicly after moderation.",
    ratingLabels: { 1: "We can improve", 2: "Good experience", 3: "Very good experience", 4: "Excellent experience", 5: "Unforgettable experience" },
  },
  it: {
    title: "Com'è stata la tua esperienza?",
    subtitle: "La tua opinione aiuta altri viaggiatori a scegliere con fiducia.",
    general: "Valutazione generale",
    details: "Dettagli dell'esperienza",
    professionalism: "Professionalità della guida",
    fun: "Divertimento",
    communication: "Comunicazione",
    quality: "Qualità delle informazioni",
    route: "Percorso e itinerario",
    publicCommentTitle: "Raccontaci la tua esperienza",
    publicCommentPlaceholder: "Cosa ti è piaciuto di più? (minimo 20 caratteri)",
    minCharacters: "Minimo 20 caratteri.",
    submitReview: "Invia recensione",
    reviewVisibility: "La tua recensione potrà essere pubblicata dopo moderazione.",
    ratingLabels: { 1: "Possiamo migliorare", 2: "Buona esperienza", 3: "Ottima esperienza", 4: "Esperienza eccellente", 5: "Esperienza indimenticabile" },
  },
  fr: {
    title: "Comment s'est passée votre expérience?",
    subtitle: "Votre avis aide d'autres voyageurs à choisir en confiance.",
    general: "Évaluation générale",
    details: "Détails de l'expérience",
    professionalism: "Professionnalisme du guide",
    fun: "Aspect divertissant",
    communication: "Communication",
    quality: "Qualité des informations",
    route: "Parcours et itinéraire",
    publicCommentTitle: "Partagez votre expérience",
    publicCommentPlaceholder: "Qu'avez-vous le plus apprécié? (minimum 20 caractères)",
    minCharacters: "Minimum 20 caractères.",
    submitReview: "Envoyer l'avis",
    reviewVisibility: "Votre avis pourra être publié après validation.",
    ratingLabels: { 1: "Nous pouvons nous améliorer", 2: "Bonne expérience", 3: "Très bonne expérience", 4: "Excellente expérience", 5: "Expérience inoubliable" },
  },
};

const t = texts[lang as string] || texts.es;

const subRatings = [
  { name: "profesionalidad", label: t.professionalism },
  { name: "diversion",       label: t.fun },
  { name: "comunicacion",    label: t.communication },
  { name: "calidad",         label: t.quality },
  { name: "ruta",            label: t.route },
];
---

<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{t.title} | BelgoTours</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: Inter, system-ui, sans-serif; background: #f3f4f6; color: #111827; min-height: 100vh; padding: 1.5rem 1rem 4rem; }

    .card { max-width: 560px; margin: 0 auto; background: #fff; border-radius: 20px; padding: 2rem 1.5rem; box-shadow: 0 4px 24px rgba(0,0,0,0.08); }
    @media(min-width:640px){ .card { padding: 2.5rem; } }

    h1 { font-size: 1.6rem; font-weight: 700; text-align: center; margin-bottom: 0.5rem; }
    .subtitle { text-align: center; color: #6b7280; font-size: 0.9rem; margin-bottom: 2rem; line-height: 1.5; }

    /* Sección */
    .section { padding-top: 1.5rem; margin-top: 1.5rem; border-top: 1px solid #f3f4f6; }
    .section-title { font-size: 1rem; font-weight: 600; margin-bottom: 1rem; }

    /* Stars */
    .stars { display: flex; gap: 6px; }
    .stars.large { gap: 10px; justify-content: center; }
    .star-btn {
      background: none; border: none; cursor: pointer; padding: 2px;
      color: #d1d5db; transition: color 0.12s, transform 0.12s;
      line-height: 1;
    }
    .star-btn svg { display: block; }
    .star-btn.active { color: #facc15; }
    .star-btn:hover { transform: scale(1.15); }
    .stars.large .star-btn svg { width: 48px; height: 48px; }
    .stars.small .star-btn svg { width: 34px; height: 34px; }

    .rating-text { text-align: center; font-size: 0.875rem; color: #6b7280; min-height: 1.4rem; margin-top: 0.75rem; transition: all 0.2s; }
    .rating-text.active { color: #111827; font-weight: 500; }

    /* Subratings grid */
    .subratings { display: grid; gap: 1.25rem; }
    @media(min-width:480px){ .subratings { grid-template-columns: 1fr 1fr; } }
    .subrating-item { }
    .subrating-label { font-size: 0.875rem; font-weight: 500; color: #374151; margin-bottom: 0.5rem; }

    /* Textarea */
    textarea {
      width: 100%; border: 1.5px solid #e5e7eb; border-radius: 12px;
      padding: 0.875rem 1rem; font-size: 0.9rem; font-family: inherit;
      resize: none; transition: border-color 0.15s;
      min-height: 120px; color: #111827;
    }
    textarea:focus { outline: none; border-color: #111827; }
    .char-count { font-size: 0.75rem; color: #9ca3af; margin-top: 0.4rem; text-align: right; }

    /* CTA */
    .btn-submit {
      width: 100%; background: #facc15; color: #111827;
      font-weight: 700; font-size: 1rem; padding: 1rem;
      border: none; border-radius: 14px; cursor: pointer;
      transition: background 0.15s, transform 0.1s;
      margin-top: 1.5rem;
    }
    .btn-submit:hover { background: #fbbf24; transform: translateY(-1px); }
    .btn-submit:disabled { background: #e5e7eb; color: #9ca3af; cursor: not-allowed; transform: none; }
    .visibility-note { text-align: center; font-size: 0.75rem; color: #9ca3af; margin-top: 0.75rem; }
  </style>
</head>
<body>
  <div class="card">
    <h1>{t.title}</h1>
    <p class="subtitle">{t.subtitle}</p>

    <form method="POST" action="/api/submit-review" id="reviewForm">
      <input type="hidden" name="token" value={token} />

      <!-- RATING GENERAL -->
      <div>
        <p class="section-title" style="text-align:center">{t.general}</p>
        <div class="stars large" id="stars-rating_general" data-name="rating_general">
          {[1,2,3,4,5].map(v => (
            <button type="button" class="star-btn" data-value={v} aria-label={`${v} estrella${v>1?'s':''}`}>
              <svg viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
              </svg>
            </button>
          ))}
        </div>
        <input type="hidden" name="rating_general" id="input-rating_general" required />
        <p class="rating-text" id="ratingText"></p>
      </div>

      <!-- SUBRATINGS -->
      <div class="section">
        <p class="section-title" style="text-align:center">{t.details}</p>
        <div class="subratings">
          {subRatings.map(sr => (
            <div class="subrating-item">
              <p class="subrating-label">{sr.label}</p>
              <div class="stars small" id={`stars-${sr.name}`} data-name={sr.name}>
                {[1,2,3,4,5].map(v => (
                  <button type="button" class="star-btn" data-value={v} aria-label={`${v}`}>
                    <svg viewBox="0 0 24 24" fill="currentColor">
                      <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
                    </svg>
                  </button>
                ))}
              </div>
              <input type="hidden" name={sr.name} id={`input-${sr.name}`} />
            </div>
          ))}
        </div>
      </div>

      <!-- COMENTARIO -->
      <div class="section">
        <p class="section-title">{t.publicCommentTitle}</p>
        <textarea
          name="comentario_publico"
          id="comentario"
          required
          minlength="20"
          maxlength="1000"
          placeholder={t.publicCommentPlaceholder}
        ></textarea>
        <p class="char-count"><span id="charCount">0</span>/1000 · {t.minCharacters}</p>
      </div>

      <!-- SUBMIT -->
      <button type="submit" class="btn-submit" id="submitBtn" disabled>
        {t.submitReview}
      </button>
      <p class="visibility-note">{t.reviewVisibility}</p>
    </form>
  </div>

  <script define:vars={{ ratingLabels: t.ratingLabels }}>
  (function() {
    // ── Star rating logic ──────────────────────────────────
    function initStars(container) {
      const name = container.dataset.name;
      const btns = Array.from(container.querySelectorAll('.star-btn'));
      const input = document.getElementById('input-' + name);

      function paint(value, isHover) {
        btns.forEach(btn => {
          const v = parseInt(btn.dataset.value);
          btn.classList.toggle('active', v <= value);
        });
      }

      function clear() {
        const current = input ? parseInt(input.value) : 0;
        paint(current || 0);
      }

      btns.forEach(btn => {
        const v = parseInt(btn.dataset.value);

        btn.addEventListener('mouseenter', () => paint(v, true));
        btn.addEventListener('mouseleave', clear);

        btn.addEventListener('click', () => {
          if (input) input.value = v;
          paint(v);

          // Feedback texto solo para rating general
          if (name === 'rating_general') {
            const textEl = document.getElementById('ratingText');
            if (textEl) {
              textEl.textContent = ratingLabels[v] || '';
              textEl.classList.add('active');
            }
            // Scroll suave a subratings
            setTimeout(() => {
              document.querySelector('.section')?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            }, 300);
          }
          checkValid();
        });

        // Touch support
        btn.addEventListener('touchstart', (e) => {
          e.preventDefault();
          if (input) input.value = v;
          paint(v);
          if (name === 'rating_general') {
            const textEl = document.getElementById('ratingText');
            if (textEl) { textEl.textContent = ratingLabels[v] || ''; textEl.classList.add('active'); }
          }
          checkValid();
        }, { passive: false });
      });
    }

    // Inicializar todos los grupos de estrellas
    document.querySelectorAll('.stars').forEach(initStars);

    // ── Contador de caracteres ─────────────────────────────
    const textarea = document.getElementById('comentario');
    const charCount = document.getElementById('charCount');

    textarea?.addEventListener('input', () => {
      const len = textarea.value.length;
      if (charCount) charCount.textContent = len;
      checkValid();
    });

    // ── Validación ─────────────────────────────────────────
    function checkValid() {
      const generalRating = document.getElementById('input-rating_general')?.value;
      const comment = document.getElementById('comentario')?.value || '';
      const submitBtn = document.getElementById('submitBtn');
      const valid = generalRating && comment.length >= 20;
      if (submitBtn) submitBtn.disabled = !valid;
    }

    checkValid();
  })();
  </script>
</body>
</html>
