---
export const prerender = false;
import AppShell from "../../../components/app/layout/AppShell.astro";
import { crmApi, crmFetch } from "../../../lib/app/apiClient";
import { can } from "../../../lib/app/permissions";

const user    = Astro.locals.user;
if (!can(user.role, "horarios", "read")) return Astro.redirect("/app");
const canEdit = can(user.role, "horarios", "write");

const p = Astro.url.searchParams;

const successMsg = p.get("success") === "creado" ? "✅ Horario creado correctamente." : "";
const errorMsg   = p.get("error")   === "duplicado" ? "⚠️ Ya existe un horario para ese tour, fecha y hora." :
                   p.get("error")   === "tiene_reservas" ? "⚠️ No se puede eliminar: tiene reservas. Ciérralo." : "";

const filters: Record<string, string> = {};
for (const [k, v] of p.entries()) {
  if (v && k !== "success" && k !== "error") filters[k] = v;
}
if (!filters.fecha_desde && !filters.fecha && !filters.fecha_hasta) {
  filters.fecha_desde = new Date().toISOString().split("T")[0];
}

// Idioma seleccionado para el formulario crear
const idiomaForm = p.get("idioma_form") || "es";

let horarios: any[] = [];
let tours: any[]    = [];
let fetchError = "";

try {
  const [horariosRes, toursResRaw] = await Promise.all([
    crmApi.horarios(user, filters),
    crmFetch(`/tours?locale=${idiomaForm}`, user),
  ]);
  horarios = horariosRes.data;
  tours    = (toursResRaw as any).data ?? [];
} catch { fetchError = "Error cargando datos."; }

const IDIOMAS = [
  { value: "es", label: "Español",  flag: "🇪🇸" },
  { value: "en", label: "English",  flag: "🇬🇧" },
  { value: "it", label: "Italiano", flag: "🇮🇹" },
  { value: "fr", label: "Français", flag: "🇫🇷" },
];
---

<AppShell title="Horarios" user={user}>
  <div class="page-top">
    <h1 class="page-title">Horarios</h1>
    <div class="top-actions">
      <a href="/app/calendario" class="btn-outline">Calendario</a>
      <a href="/app/horarios/recurrencias" class="btn-outline">Recurrencias</a>
    </div>
  </div>

  {successMsg && <div class="alert-success">{successMsg}</div>}
  {(errorMsg || fetchError) && <div class="alert-error">{errorMsg || fetchError}</div>}

  <!-- Filtros de lista -->
  <form class="filters" method="GET">
    <input type="hidden" name="idioma_form" value={idiomaForm} />
    <input type="date" name="fecha_desde" value={p.get("fecha_desde") ?? filters.fecha_desde ?? ""} />
    <input type="date" name="fecha_hasta" value={p.get("fecha_hasta") ?? ""} />
    <select name="tour_id">
      <option value="">Todos los tours</option>
      {tours.map((t: any) => (
        <option value={t.id} selected={p.get("tour_id") === String(t.id)}>
          {t.titulo}
        </option>
      ))}
    </select>
    <select name="disponible">
      <option value="">Todos</option>
      <option value="true"  selected={p.get("disponible") === "true"}>Abiertos</option>
      <option value="false" selected={p.get("disponible") === "false"}>Cerrados</option>
    </select>
    <button type="submit" class="btn-primary">Filtrar</button>
    <a href="/app/horarios" class="btn-ghost">Limpiar</a>
  </form>

  <!-- Tabla -->
  <div class="table-wrap">
    <table class="table">
      <thead>
        <tr>
          <th>Fecha</th>
          <th>Hora</th>
          <th>Tour</th>
          <th>Cupo</th>
          <th>Reservas</th>
          <th>Estado</th>
          {canEdit && <th>Acciones</th>}
        </tr>
      </thead>
      <tbody>
        {horarios.length === 0 && (
          <tr><td colspan="7" class="empty-row">No hay horarios en este rango.</td></tr>
        )}
        {horarios.map((h: any) => (
          <tr class:list={[{ "row-cerrado": !h.disponible }]}>
            <td>{new Date(h.fecha + "T12:00:00").toLocaleDateString("es-ES", { weekday:"short", day:"numeric", month:"short" })}</td>
            <td class="td-hora">{h.hora}</td>
            <td>
              <a href={`/app/horarios/${h.id}`} class="tour-link">{h.tour?.titulo ?? "—"}</a>
              {h.recurrencia?.idioma && <span class="lang-tag">{h.recurrencia.idioma.toUpperCase()}</span>}
            </td>
            <td class="td-center">{h.cupoMaximo ?? "—"}</td>
            <td class="td-center">
              <span class:list={["reservas-num", { "has-reservas": (h.cupoOcupado || 0) > 0 }]}>
                {h.cupoOcupado ?? 0}
              </span>
            </td>
            <td>
              <span class:list={["badge", h.disponible ? "badge-abierto" : "badge-cerrado"]}>
                {h.disponible ? "Abierto" : "Cerrado"}
              </span>
            </td>
            {canEdit && (
              <td>
                <div class="action-btns">
                  <a href={`/app/horarios/${h.id}`} class="btn-ver">Ver</a>
                  <form method="POST" action="/api/app/horario-toggle" style="display:inline">
                    <input type="hidden" name="id" value={h.id} />
                    <input type="hidden" name="disponible" value={h.disponible ? "false" : "true"} />
                    <input type="hidden" name="redirect" value={Astro.url.pathname + "?" + new URLSearchParams(filters).toString()} />
                    <button type="submit" class:list={["btn-toggle", h.disponible ? "btn-cerrar" : "btn-abrir"]}>
                      {h.disponible ? "Cerrar" : "Abrir"}
                    </button>
                  </form>
                  {(h.cupoOcupado || 0) === 0 ? (
                    <form method="POST" action="/api/app/horario-delete" style="display:inline"
                          onsubmit="return confirm('¿Eliminar este horario? Desaparecerá del frontend.')">
                      <input type="hidden" name="id" value={h.id} />
                      <input type="hidden" name="redirect" value={Astro.url.pathname + "?" + new URLSearchParams(filters).toString()} />
                      <button type="submit" class="btn-eliminar">Eliminar</button>
                    </form>
                  ) : (
                    <span class="btn-locked" title={`${h.cupoOcupado} reservas`}>🔒</span>
                  )}
                </div>
              </td>
            )}
          </tr>
        ))}
      </tbody>
    </table>
  </div>
  <div class="table-footer">Total: <strong>{horarios.length}</strong> horarios</div>

  <!-- Crear horario puntual -->
  {canEdit && (
    <div class="crear-section">
      <h2 class="section-title">Crear horario puntual</h2>
      <div class="crear-card">

        <!-- Paso 1: idioma -->
        <div class="paso-bloque">
          <div class="paso-label"><span class="paso-num">1</span> Idioma del tour</div>
          <div class="idioma-btns">
            {IDIOMAS.map(i => (
              <a href={`/app/horarios?idioma_form=${i.value}`}
                 class:list={["idioma-btn", { "idioma-active": idiomaForm === i.value }]}>
                <span class="idioma-flag">{i.flag}</span>
                <span class="idioma-label">{i.label}</span>
              </a>
            ))}
          </div>
        </div>

        <!-- Paso 2: tour cards -->
        <div class="paso-bloque">
          <div class="paso-label"><span class="paso-num">2</span> Selecciona el tour</div>
          {tours.length === 0 ? (
            <div class="no-tours">No hay tours en {idiomaForm.toUpperCase()}. Créalos primero en Strapi.</div>
          ) : (
            <div class="tour-cards" id="tour-cards">
              {tours.map((t: any) => (
                <label class="tour-card">
                  <input type="radio" name="tour_id_selector" value={t.id}
                         onchange={`document.getElementById('tour_id_hidden').value=this.value`} />
                  <div class="tour-card-inner">
                    <div class="tour-card-tipo">
                      {t.tipo_tour === 'free' ? '🎯 Free Tour' : t.tipo_tour === 'privado' ? '👤 Privado' : '⭐ Especial'}
                    </div>
                    <div class="tour-card-nombre">{t.titulo?.split('–')[0]?.trim() ?? t.titulo}</div>
                    <div class="tour-card-ciudad">📍 {t.ciudad?.charAt(0).toUpperCase() + t.ciudad?.slice(1)}</div>
                  </div>
                </label>
              ))}
            </div>
          )}
        </div>

        <!-- Paso 3: fecha, hora, cupo -->
        <form method="POST" action="/api/app/horario-crear" class="crear-form" id="form-crear-horario">
          <input type="hidden" name="redirect" value={Astro.url.pathname} />
          <input type="hidden" name="tour_id" id="tour_id_hidden" value="" />
          <div class="paso-bloque">
            <div class="paso-label"><span class="paso-num">3</span> Fecha, hora y cupo</div>
            <div class="form-row-3">
              <div class="form-field">
                <label>Fecha *</label>
                <input type="date" name="fecha" required
                       min={new Date().toISOString().split("T")[0]}
                       value={new Date().toISOString().split("T")[0]} />
              </div>
              <div class="form-field">
                <label>Hora *</label>
                <input type="time" name="hora" required />
              </div>
              <div class="form-field">
                <label>Cupo máximo</label>
                <input type="number" name="cupoMaximo" value="25" min="1" max="200" />
              </div>
            </div>
          </div>
          <button type="submit" class="btn-crear"
                  onclick="if(!document.getElementById('tour_id_hidden').value){alert('Selecciona un tour primero');return false}">
            + Crear horario
          </button>
        </form>
      </div>
    </div>
  )}
</AppShell>

<style>
  .page-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.25rem; }
  .page-title { font-size: 1.5rem; font-weight: 700; color: #111827; }
  .top-actions { display: flex; gap: 0.5rem; }
  .filters { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1.25rem; }
  .filters input, .filters select { padding: 0.45rem 0.75rem; border: 1px solid #d1d5db; border-radius: 7px; font-size: 0.85rem; background: #fff; color: #111827; outline: none; }
  .btn-primary  { background: #2563eb; color: #fff; border: none; border-radius: 7px; padding: 0.45rem 1rem; font-size: 0.85rem; cursor: pointer; }
  .btn-outline  { background: #fff; color: #374151; border: 1px solid #d1d5db; border-radius: 7px; padding: 0.45rem 0.875rem; font-size: 0.85rem; text-decoration: none; }
  .btn-ghost    { color: #6b7280; font-size: 0.85rem; padding: 0.45rem 0.5rem; text-decoration: none; }
  .alert-success { background: #f0fdf4; border: 1px solid #86efac; color: #166534; padding: 0.75rem 1rem; border-radius: 8px; margin-bottom: 1rem; font-size: 0.875rem; }
  .alert-error   { background: #fef2f2; border: 1px solid #fecaca; color: #991b1b; padding: 0.75rem 1rem; border-radius: 8px; margin-bottom: 1rem; font-size: 0.875rem; }
  .table-wrap   { overflow-x: auto; background: #fff; border: 1px solid #e5e7eb; border-radius: 10px; }
  .table        { width: 100%; border-collapse: collapse; font-size: 0.85rem; }
  .table th     { text-align: left; padding: 0.7rem 1rem; background: #f9fafb; color: #6b7280; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.04em; border-bottom: 1px solid #e5e7eb; font-weight: 600; }
  .table td     { padding: 0.75rem 1rem; border-bottom: 1px solid #f3f4f6; vertical-align: middle; }
  .table tr:last-child td { border-bottom: none; }
  .table tr:hover td { background: #f9fafb; }
  .row-cerrado td { opacity: 0.55; }
  .empty-row    { text-align: center; color: #9ca3af; padding: 2rem !important; }
  .td-hora      { font-family: monospace; font-weight: 700; font-size: 0.95rem; }
  .td-center    { text-align: center; }
  .tour-link    { color: #1f2937; text-decoration: none; font-weight: 500; }
  .tour-link:hover { color: #2563eb; }
  .lang-tag     { font-size: 0.7rem; background: #eff6ff; color: #1d4ed8; padding: 0.1rem 0.35rem; border-radius: 4px; font-weight: 600; margin-left: 0.35rem; }
  .badge        { font-size: 0.72rem; font-weight: 600; padding: 0.2rem 0.55rem; border-radius: 999px; }
  .badge-abierto { background: #dcfce7; color: #166534; }
  .badge-cerrado { background: #fee2e2; color: #991b1b; }
  .reservas-num  { font-weight: 600; color: #9ca3af; }
  .has-reservas  { color: #2563eb; }
  .action-btns  { display: flex; gap: 0.35rem; align-items: center; flex-wrap: wrap; }
  .btn-ver      { color: #2563eb; text-decoration: none; font-size: 0.8rem; font-weight: 500; }
  .btn-toggle   { border: none; border-radius: 6px; padding: 0.3rem 0.65rem; font-size: 0.78rem; cursor: pointer; font-weight: 600; }
  .btn-cerrar   { background: #fee2e2; color: #991b1b; }
  .btn-cerrar:hover { background: #fecaca; }
  .btn-abrir    { background: #dcfce7; color: #166534; }
  .btn-abrir:hover  { background: #bbf7d0; }
  .btn-eliminar { background: #374151; color: #fff; border: none; border-radius: 6px; padding: 0.3rem 0.65rem; font-size: 0.78rem; cursor: pointer; font-weight: 600; }
  .btn-eliminar:hover { background: #111827; }
  .btn-locked   { font-size: 0.85rem; opacity: 0.4; cursor: help; }
  .table-footer { padding: 0.75rem 0; color: #6b7280; font-size: 0.85rem; }
  .crear-section { margin-top: 2rem; }
  .section-title { font-size: 1rem; font-weight: 700; color: #111827; margin-bottom: 0.875rem; }
  .crear-card { background: #fff; border: 1px solid #e5e7eb; border-radius: 10px; padding: 1.5rem; display: flex; flex-direction: column; gap: 1.25rem; }
  .paso-bloque { display: flex; flex-direction: column; gap: 0.75rem; }
  .paso-label { display: flex; align-items: center; gap: 0.5rem; font-size: 0.8rem; font-weight: 700; color: #374151; text-transform: uppercase; letter-spacing: 0.05em; }
  .paso-num { display: inline-flex; align-items: center; justify-content: center; width: 22px; height: 22px; background: #2563eb; color: #fff; border-radius: 50%; font-size: 0.75rem; font-weight: 700; flex-shrink: 0; }
  .idioma-btns { display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .idioma-btn { display: flex; align-items: center; gap: 0.4rem; padding: 0.5rem 1rem; border: 2px solid #e5e7eb; border-radius: 10px; text-decoration: none; font-size: 0.875rem; font-weight: 500; color: #374151; background: #fff; transition: all 0.15s; }
  .idioma-btn:hover { border-color: #93c5fd; background: #f0f9ff; }
  .idioma-active { border-color: #2563eb; background: #eff6ff; color: #1d4ed8; font-weight: 700; box-shadow: 0 0 0 3px rgba(37,99,235,0.1); }
  .idioma-flag { font-size: 1.1rem; }
  .idioma-label { font-size: 0.85rem; }
  .tour-cards { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 0.75rem; }
  .tour-card { cursor: pointer; }
  .tour-card input[type="radio"] { display: none; }
  .tour-card-inner { border: 2px solid #e5e7eb; border-radius: 10px; padding: 1rem; background: #fff; transition: all 0.15s; display: flex; flex-direction: column; gap: 0.3rem; }
  .tour-card:hover .tour-card-inner { border-color: #93c5fd; background: #f0f9ff; }
  .tour-card input:checked + .tour-card-inner { border-color: #2563eb; background: #eff6ff; box-shadow: 0 0 0 3px rgba(37,99,235,0.12); }
  .tour-card-tipo { font-size: 0.72rem; font-weight: 700; color: #6b7280; text-transform: uppercase; letter-spacing: 0.04em; }
  .tour-card-nombre { font-size: 0.9rem; font-weight: 700; color: #111827; line-height: 1.3; }
  .tour-card-ciudad { font-size: 0.78rem; color: #6b7280; }
  .no-tours { background: #fef9c3; border: 1px solid #fde68a; color: #854d0e; padding: 0.75rem 1rem; border-radius: 8px; font-size: 0.875rem; }
  .form-row-3 { display: flex; gap: 1rem; flex-wrap: wrap; }
  .crear-form { display: flex; flex-direction: column; gap: 1rem; }
  .form-row { display: flex; gap: 1rem; flex-wrap: wrap; }
  .form-field { display: flex; flex-direction: column; gap: 0.35rem; flex: 1; min-width: 160px; }
  .form-field label { font-size: 0.78rem; color: #6b7280; text-transform: uppercase; letter-spacing: 0.04em; font-weight: 600; }
  .form-field select, .form-field input { padding: 0.55rem 0.75rem; border: 1px solid #d1d5db; border-radius: 7px; font-size: 0.875rem; color: #111827; background: #fff; outline: none; }
  .form-field select:focus, .form-field input:focus { border-color: #3b82f6; }
  .btn-crear { background: #2563eb; color: #fff; border: none; border-radius: 8px; padding: 0.65rem 1.5rem; font-size: 0.9rem; font-weight: 600; cursor: pointer; align-self: flex-start; }
  .btn-crear:hover { background: #1d4ed8; }
</style>
