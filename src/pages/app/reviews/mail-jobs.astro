---
export const prerender = false;
import AppShell from '../../../components/app/layout/AppShell.astro';
import { crmApi } from '../../../lib/app/apiClient';
import { can } from '../../../lib/app/permissions';

const user = Astro.locals.user;
if (!can(user.role, 'mail_jobs', 'read')) return Astro.redirect('/app');

const p = Astro.url.searchParams;
const filters: Record<string, string> = {};
for (const [k, v] of p.entries()) { if (v) filters[k] = v; }
if (!filters.status) filters.status = 'failed';

let result: any = { data: [], meta: { pagination: { total: 0 } } };
let errorMsg = '';
try { result = await crmApi.mailJobs(user, filters); }
catch { errorMsg = 'Error cargando cola de emails.'; }
---

<AppShell title="Cola de emails" user={user}>
  <div class="page-top">
    <div class="breadcrumb">
      <a href="/app/reviews">← Reviews</a>
      <span>Cola de emails</span>
    </div>
  </div>

  <form class="filters" method="GET">
    <select name="status">
      <option value="">Todos</option>
      {['pending','sent','failed'].map(s => (
        <option value={s} selected={(p.get('status') ?? 'failed') === s}>{s}</option>
      ))}
    </select>
    <select name="type">
      <option value="">Tipo</option>
      {['reservation','review','reminder','other'].map(t => (
        <option value={t} selected={p.get('type') === t}>{t}</option>
      ))}
    </select>
    <button type="submit" class="btn-primary">Filtrar</button>
    <a href="/app/reviews/mail-jobs" class="btn-ghost">Limpiar</a>
  </form>

  {errorMsg && <div class="alert-error">{errorMsg}</div>}

  <div class="table-wrap">
    <table class="table">
      <thead>
        <tr>
          <th>Destinatario</th>
          <th>Asunto</th>
          <th>Tipo</th>
          <th>Estado</th>
          <th>Intentos</th>
          <th>Reserva</th>
          <th>Programado</th>
          <th>Enviado</th>
          <th>Error</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        {result.data.length === 0 && (
          <tr><td colspan="10" class="empty-row">No hay emails con estos filtros.</td></tr>
        )}
        {result.data.map((j: any) => (
          <tr>
            <td class="td-email">{j.email_to}</td>
            <td class="td-subject">{j.subject}</td>
            <td><span class={`badge badge-type-${j.type}`}>{j.type}</span></td>
            <td><span class={`badge badge-${j.status}`}>{j.status}</span></td>
            <td class="td-center">{j.retries}</td>
            <td>
              {j.related_reservation
                ? <a href={`/app/reservas/${j.related_reservation.id}`} class="link-reserva">
                    #{j.related_reservation.id}
                  </a>
                : '—'}
            </td>
            <td class="td-small">{j.scheduled_at ? new Date(j.scheduled_at).toLocaleString('es-ES') : '—'}</td>
            <td class="td-small">{j.sent_at ? new Date(j.sent_at).toLocaleString('es-ES') : '—'}</td>
            <td class="td-error">{j.error_message ?? '—'}</td>
            <td>
              {j.status === 'failed' && (
                <form method="POST" action="/api/app/mail-job-retry">
                  <input type="hidden" name="id" value={j.id} />
                  <input type="hidden" name="redirect" value={Astro.url.pathname + Astro.url.search} />
                  <button type="submit" class="btn-retry">Reintentar</button>
                </form>
              )}
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
  <div class="table-footer">Total: <strong>{result.meta.pagination.total}</strong> emails</div>
</AppShell>

<style>
  .page-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.25rem; }
  .breadcrumb { display: flex; align-items: center; gap: 0.75rem; font-size: 0.875rem; }
  .breadcrumb a { color: #2563eb; text-decoration: none; }
  .breadcrumb span { color: #6b7280; }
  .filters { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1.25rem; }
  .filters select { padding: 0.45rem 0.75rem; border: 1px solid #d1d5db; border-radius: 7px; font-size: 0.85rem; background: #fff; color: #111827; outline: none; }
  .btn-primary { background: #2563eb; color: #fff; border: none; border-radius: 7px; padding: 0.45rem 1rem; font-size: 0.85rem; cursor: pointer; }
  .btn-ghost   { color: #6b7280; font-size: 0.85rem; padding: 0.45rem 0.5rem; text-decoration: none; }
  .alert-error { background: #fef2f2; border: 1px solid #fecaca; color: #991b1b; padding: 0.75rem 1rem; border-radius: 8px; margin-bottom: 1rem; font-size: 0.85rem; }
  .table-wrap  { overflow-x: auto; background: #fff; border: 1px solid #e5e7eb; border-radius: 10px; }
  .table       { width: 100%; border-collapse: collapse; font-size: 0.82rem; }
  .table th    { text-align: left; padding: 0.65rem 0.875rem; background: #f9fafb; color: #6b7280; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.04em; border-bottom: 1px solid #e5e7eb; font-weight: 600; }
  .table td    { padding: 0.75rem 0.875rem; border-bottom: 1px solid #f3f4f6; vertical-align: middle; }
  .table tr:last-child td { border-bottom: none; }
  .table tr:hover td { background: #f9fafb; }
  .empty-row   { text-align: center; color: #9ca3af; padding: 2rem !important; }
  .td-email    { font-size: 0.8rem; max-width: 180px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .td-subject  { max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .td-center   { text-align: center; }
  .td-small    { font-size: 0.75rem; color: #6b7280; white-space: nowrap; }
  .td-error    { font-size: 0.75rem; color: #ef4444; max-width: 160px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .badge       { font-size: 0.72rem; font-weight: 600; padding: 0.2rem 0.5rem; border-radius: 999px; }
  .badge-pending { background: #fef9c3; color: #854d0e; }
  .badge-sent    { background: #dcfce7; color: #166534; }
  .badge-failed  { background: #fee2e2; color: #991b1b; }
  .badge-type-review      { background: #f5f3ff; color: #5b21b6; }
  .badge-type-reservation { background: #eff6ff; color: #1e40af; }
  .badge-type-reminder    { background: #fff7ed; color: #9a3412; }
  .badge-type-other       { background: #f3f4f6; color: #374151; }
  .link-reserva { color: #2563eb; text-decoration: none; font-weight: 500; }
  .btn-retry    { background: #fef3c7; color: #92400e; border: 1px solid #fcd34d; border-radius: 6px; padding: 0.3rem 0.65rem; font-size: 0.78rem; cursor: pointer; font-weight: 600; white-space: nowrap; }
  .btn-retry:hover { background: #fde68a; }
  .table-footer { padding: 0.75rem 0; color: #6b7280; font-size: 0.85rem; }
</style>
