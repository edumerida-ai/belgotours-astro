---
// SSR redirect — sin pantalla intermedia, sin loader
export const prerender = false;

const LANGS = ['es', 'en', 'it', 'fr', 'pt'];
const FALLBACK = 'en';

// Leer Accept-Language del header del navegador (server-side)
const acceptLang = Astro.request.headers.get('accept-language') || '';

// Parsear el header y encontrar el mejor idioma
function detectLang(header: string): string {
  if (!header) return FALLBACK;
  // Formato: "es-ES,es;q=0.9,en;q=0.8"
  const langs = header
    .split(',')
    .map(l => {
      const [code, q] = l.trim().split(';q=');
      return { code: code.split('-')[0].toLowerCase(), q: q ? parseFloat(q) : 1.0 };
    })
    .sort((a, b) => b.q - a.q);

  for (const { code } of langs) {
    if (LANGS.includes(code)) return code;
  }
  return FALLBACK;
}

const lang = detectLang(acceptLang);

// Redirect 302 server-side — instantáneo, sin JS, sin loader
return Astro.redirect(`/${lang}/`, 302);
---
