---
// src/components/booking/BookingSteps.astro

interface Props {
  currentStep: number;
  lang: string;
}

const { currentStep, lang } = Astro.props;

const steps = [
  { 
    number: 1, 
    label: {
      es: 'Fecha & Grupo',
      en: 'Date & Group', 
      it: 'Data & Gruppo',
      fr: 'Date & Groupe',
      pt: 'Data & Grupo'
    }
  },
  { 
    number: 2, 
    label: {
      es: 'Tus Datos',
      en: 'Your Details',
      it: 'I tuoi Dati', 
      fr: 'Vos Coordonnées',
      pt: 'Seus Dados'
    }
  },
  { 
    number: 3, 
    label: {
      es: 'Confirmar',
      en: 'Confirm',
      it: 'Conferma',
      fr: 'Confirmer', 
      pt: 'Confirmar'
    }
  }
];
---

<div class="flex justify-center mb-6">
  <div class="flex items-center gap-4 md:gap-6 text-sm md:text-base font-medium">

    {steps.map((step) => (
      <span
        class={`transition-colors duration-200 ${
          currentStep === step.number
            ? "text-gray-900 font-semibold"
            : currentStep > step.number
            ? "text-gray-700"
            : "text-gray-400"
        }`}
      >
        {step.label[lang as keyof typeof step.label] || step.label.es}
      </span>
    ))}

  </div>
</div>