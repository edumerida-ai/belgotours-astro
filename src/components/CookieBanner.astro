---
interface Props { lang: string; }
const { lang = "es" } = Astro.props;

const t: Record<string, any> = {
  es: { text: "Usamos cookies para mejorar tu experiencia y analizar el tráfico.", more: "Más info", accept: "Aceptar", reject: "Rechazar", settings: "Configurar", panelTitle: "Preferencias de cookies", essential: "Esenciales", essentialDesc: "Necesarias para el funcionamiento", analytics: "Analíticas", analyticsDesc: "Nos ayudan a mejorar la web", marketing: "Marketing", marketingDesc: "Contenido personalizado", save: "Guardar" },
  en: { text: "We use cookies to improve your experience and analyze traffic.", more: "Learn more", accept: "Accept", reject: "Reject", settings: "Customize", panelTitle: "Cookie preferences", essential: "Essential", essentialDesc: "Required for site functionality", analytics: "Analytics", analyticsDesc: "Help us improve", marketing: "Marketing", marketingDesc: "Personalized content", save: "Save" },
  it: { text: "Utilizziamo cookie per migliorare la tua esperienza e analizzare il traffico.", more: "Maggiori info", accept: "Accetta", reject: "Rifiuta", settings: "Configura", panelTitle: "Preferenze cookie", essential: "Essenziali", essentialDesc: "Necessari per il sito", analytics: "Analitici", analyticsDesc: "Ci aiutano a migliorare", marketing: "Marketing", marketingDesc: "Contenuto personalizzato", save: "Salva" },
  fr: { text: "Nous utilisons des cookies pour améliorer votre expérience et analyser le trafic.", more: "En savoir plus", accept: "Accepter", reject: "Refuser", settings: "Configurer", panelTitle: "Préférences cookies", essential: "Essentiels", essentialDesc: "Nécessaires au fonctionnement", analytics: "Analytiques", analyticsDesc: "Nous aident à améliorer", marketing: "Marketing", marketingDesc: "Contenu personnalisé", save: "Enregistrer" },
  pt: { text: "Usamos cookies para melhorar sua experiência e analisar o tráfego.", more: "Saiba mais", accept: "Aceitar", reject: "Rejeitar", settings: "Configurar", panelTitle: "Preferências de cookies", essential: "Essenciais", essentialDesc: "Necessários para o site", analytics: "Analíticos", analyticsDesc: "Nos ajudam a melhorar", marketing: "Marketing", marketingDesc: "Conteúdo personalizado", save: "Salvar" },
};
const c = t[lang] || t.en;
---

<!-- Banner compacto — oculto por defecto hasta que JS lo muestre -->
<div id="cookie-banner" class="cookie-banner" role="dialog" aria-label="Cookie consent" style="display:none">
  <div class="cookie-inner">
    <p class="cookie-text">
      {c.text}
      <a href={`/${lang}/cookies`} class="cookie-link">{c.more}</a>
    </p>
    <div class="cookie-actions">
      <button id="cookie-settings-btn" class="btn-cookie-secondary">{c.settings}</button>
      <button id="cookie-reject-btn" class="btn-cookie-secondary">{c.reject}</button>
      <button id="cookie-accept-btn" class="btn-cookie-primary">{c.accept}</button>
    </div>
  </div>
</div>

<!-- Panel de configuración -->
<div id="cookie-panel" class="cookie-panel" style="display:none" role="dialog">
  <div class="cookie-panel-inner">
    <div class="cookie-panel-header">
      <h3 class="cookie-panel-title">{c.panelTitle}</h3>
      <button id="cookie-panel-close" class="cookie-panel-close">✕</button>
    </div>
    <div class="cookie-panel-body">
      <label class="cookie-option">
        <div>
          <div class="cookie-option-name">{c.essential}</div>
          <div class="cookie-option-desc">{c.essentialDesc}</div>
        </div>
        <input type="checkbox" checked disabled class="cookie-check" />
      </label>
      <label class="cookie-option">
        <div>
          <div class="cookie-option-name">{c.analytics}</div>
          <div class="cookie-option-desc">{c.analyticsDesc}</div>
        </div>
        <input type="checkbox" id="analytics-check" checked class="cookie-check" />
      </label>
      <label class="cookie-option">
        <div>
          <div class="cookie-option-name">{c.marketing}</div>
          <div class="cookie-option-desc">{c.marketingDesc}</div>
        </div>
        <input type="checkbox" id="marketing-check" class="cookie-check" />
      </label>
    </div>
    <div class="cookie-panel-footer">
      <button id="cookie-save-btn" class="btn-cookie-primary">{c.save}</button>
    </div>
  </div>
</div>

<style>
  .cookie-banner {
    position: fixed;
    bottom: 1rem;
    left: 1rem;
    right: 1rem;
    z-index: 9999;
    max-width: 680px;
    margin: 0 auto;
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 14px;
    box-shadow: 0 4px 24px rgba(0,0,0,0.10);
    padding: 1rem 1.25rem;
  }
  @media (min-width: 768px) {
    .cookie-banner {
      left: auto;
      right: 1.5rem;
      bottom: 1.5rem;
      max-width: 480px;
    }
  }
  .cookie-inner { display: flex; flex-direction: column; gap: 0.75rem; }
  .cookie-text { font-size: 0.82rem; color: #374151; line-height: 1.5; margin: 0; }
  .cookie-link { color: #2563eb; text-decoration: underline; margin-left: 0.25rem; }
  .cookie-actions { display: flex; gap: 0.5rem; flex-wrap: wrap; align-items: center; justify-content: flex-end; }
  .btn-cookie-primary {
    background: #facc15;
    color: #111827;
    border: none;
    border-radius: 8px;
    padding: 0.45rem 1rem;
    font-size: 0.82rem;
    font-weight: 700;
    cursor: pointer;
    transition: background 0.15s;
  }
  .btn-cookie-primary:hover { background: #fbbf24; }
  .btn-cookie-secondary {
    background: transparent;
    color: #6b7280;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    padding: 0.45rem 0.875rem;
    font-size: 0.82rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.15s;
  }
  .btn-cookie-secondary:hover { color: #111827; border-color: #d1d5db; }

  /* Panel */
  .cookie-panel {
    position: fixed;
    inset: 0;
    z-index: 10000;
    background: rgba(0,0,0,0.5);
    display: flex;
    align-items: flex-end;
    justify-content: center;
  }
  @media (min-width: 640px) {
    .cookie-panel { align-items: center; }
  }
  .cookie-panel-inner {
    background: #fff;
    border-radius: 16px 16px 0 0;
    padding: 1.5rem;
    width: 100%;
    max-width: 480px;
    max-height: 80vh;
    overflow-y: auto;
  }
  @media (min-width: 640px) {
    .cookie-panel-inner { border-radius: 16px; }
  }
  .cookie-panel-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.25rem; }
  .cookie-panel-title { font-size: 1rem; font-weight: 700; color: #111827; margin: 0; }
  .cookie-panel-close { background: none; border: none; font-size: 1.1rem; color: #6b7280; cursor: pointer; padding: 0.25rem; }
  .cookie-panel-body { display: flex; flex-direction: column; gap: 0.875rem; margin-bottom: 1.25rem; }
  .cookie-option { display: flex; justify-content: space-between; align-items: center; gap: 1rem; padding: 0.75rem; background: #f9fafb; border-radius: 10px; cursor: pointer; }
  .cookie-option-name { font-size: 0.875rem; font-weight: 600; color: #111827; }
  .cookie-option-desc { font-size: 0.75rem; color: #6b7280; margin-top: 0.15rem; }
  .cookie-check { width: 1.1rem; height: 1.1rem; accent-color: #facc15; flex-shrink: 0; cursor: pointer; }
  .cookie-panel-footer { display: flex; justify-content: flex-end; }
</style>

<script define:vars={{ COOKIE_KEY: "belgotours_cookie_consent" }}>
(function() {
  // Si ya hay consentimiento, no mostrar
  if (localStorage.getItem(COOKIE_KEY)) return;

  const banner  = document.getElementById("cookie-banner");
  const panel   = document.getElementById("cookie-panel");
  const acceptBtn  = document.getElementById("cookie-accept-btn");
  const rejectBtn  = document.getElementById("cookie-reject-btn");
  const settingsBtn = document.getElementById("cookie-settings-btn");
  const saveBtn    = document.getElementById("cookie-save-btn");
  const closeBtn   = document.getElementById("cookie-panel-close");

  // Mostrar banner con pequeño delay para no bloquear LCP
  setTimeout(() => {
    if (banner) banner.style.display = "block";
  }, 800);

  function save(prefs) {
    localStorage.setItem(COOKIE_KEY, JSON.stringify(prefs));
    if (banner) banner.style.display = "none";
    if (panel)  panel.style.display  = "none";
  }

  acceptBtn?.addEventListener("click", () => {
    save({ essential: true, analytics: true, marketing: true });
  });

  rejectBtn?.addEventListener("click", () => {
    save({ essential: true, analytics: false, marketing: false });
  });

  settingsBtn?.addEventListener("click", () => {
    if (banner) banner.style.display = "none";
    if (panel)  panel.style.display  = "flex";
  });

  closeBtn?.addEventListener("click", () => {
    if (panel)  panel.style.display  = "none";
    if (banner) banner.style.display = "block";
  });

  saveBtn?.addEventListener("click", () => {
    const analytics = (document.getElementById("analytics-check"))?.checked ?? true;
    const marketing = (document.getElementById("marketing-check"))?.checked ?? false;
    save({ essential: true, analytics, marketing });
  });
})();
</script>
