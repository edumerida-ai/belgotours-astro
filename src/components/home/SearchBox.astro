---
interface Tour {
  name: string;
  duration: string;
  price: string;
  tourLang: "es" | "en" | "it" | "fr";
  city: "brussels" | "bruges" | "antwerp" | "leuven";
  kind: "free" | "private" | "special";
  url: string;
}

interface Props {
  lang: "es" | "en" | "it" | "fr" | "pt";
  title: string;
  subtitle: string;
  tours?: Tour[];
  ctaLabel: string;
}

const { lang, title, subtitle, tours = [] } = Astro.props;

const TEXTS = {
  es: { cityLabel: "¿A qué ciudad vas?", langLabel: "¿En qué idioma quieres el tour?", toursLabel: "Elige tu tour", cities: { brussels: "Bruselas", bruges: "Brujas", antwerp: "Amberes (próximamente)", leuven: "Lovaina (próximamente)" }, kinds: { free: "Free Tour", private: "Tour Privado", special: "Tour Especial" }, free: "Pago libre", perPerson: "por persona", perGroup: "por grupo", noTours: "No hay tours para este idioma. Prueba con otro." },
  en: { cityLabel: "Which city?", langLabel: "Which language?", toursLabel: "Choose your tour", cities: { brussels: "Brussels", bruges: "Bruges", antwerp: "Antwerp (coming soon)", leuven: "Leuven (coming soon)" }, kinds: { free: "Free Tour", private: "Private Tour", special: "Special Tour" }, free: "Pay what you want", perPerson: "per person", perGroup: "per group", noTours: "No tours for this language. Try another." },
  it: { cityLabel: "Quale città?", langLabel: "In che lingua?", toursLabel: "Scegli il tuo tour", cities: { brussels: "Bruxelles", bruges: "Bruges", antwerp: "Anversa (presto)", leuven: "Lovanio (presto)" }, kinds: { free: "Free Tour", private: "Tour Privato", special: "Tour Speciale" }, free: "Prezzo libero", perPerson: "a persona", perGroup: "per gruppo", noTours: "Nessun tour per questa lingua." },
  fr: { cityLabel: "Quelle ville?", langLabel: "Quelle langue?", toursLabel: "Choisissez votre visite", cities: { brussels: "Bruxelles", bruges: "Bruges", antwerp: "💎 Anvers (bientôt)", leuven: "🍺 Louvain (bientôt)" }, kinds: { free: "Free Tour", private: "Tour Privé", special: "Tour Spécial" }, free: "Contribution libre", perPerson: "par personne", perGroup: "par groupe", noTours: "Aucun tour pour cette langue." },
  pt: { cityLabel: "Qual cidade?", langLabel: "Em que idioma?", toursLabel: "Escolha seu tour", cities: { brussels: "Bruxelas", bruges: "Bruges", antwerp: "Antuérpia (em breve)", leuven: "Lovaina (em breve)" }, kinds: { free: "Free Tour", private: "Tour Privado", special: "Tour Especial" }, free: "Preço livre", perPerson: "por pessoa", perGroup: "por grupo", noTours: "Nenhum tour para este idioma." },
};

const t = TEXTS[lang] ?? TEXTS.es;

const LANG_META: Record<string, { label: string; flag: string }> = {
  es: { label: "Español", flag: "🇪🇸" },
  en: { label: "English", flag: "🇬🇧" },
  it: { label: "Italiano", flag: "🇮🇹" },
  fr: { label: "Français", flag: "🇫🇷" },
};

const ALL_LANGS = ["es", "en", "it", "fr"] as const;
const ALL_CITIES = ["brussels", "bruges", "antwerp", "leuven"] as const;

// Preseleccionar idioma según el lang de la página
const defaultLang = (["es","en","it","fr"].includes(lang) ? lang : null) as string | null;
---

<div class="max-w-2xl mx-auto bg-white rounded-3xl border border-neutral-200 shadow-xl overflow-hidden mt-6 lg:mt-10 relative z-[70]">

  <!-- PASO 1: CIUDAD -->
  <div id="sb-step-city" class="p-6 border-b border-neutral-100">
    <div class="text-xs font-bold text-neutral-400 uppercase tracking-widest mb-3">
      {t.cityLabel}
    </div>
    <div class="grid grid-cols-2 gap-2" id="sb-cities">
      {ALL_CITIES.map(city => {
        const isFuture = city === "antwerp" || city === "leuven";
        return (
          <button
            type="button"
            data-city={city}
            disabled={isFuture}
            class:list={[
              "city-btn text-left px-4 py-3 rounded-xl border-2 text-sm font-medium transition-all duration-150",
              city === "brussels" ? "border-yellow-400 bg-yellow-50 text-neutral-900" : "border-neutral-200 bg-white text-neutral-700",
              isFuture ? "opacity-40 cursor-not-allowed" : "hover:border-yellow-300 hover:bg-yellow-50 cursor-pointer"
            ]}
          >
            {t.cities[city]}
          </button>
        );
      })}
    </div>
  </div>

  <!-- PASO 2: IDIOMA -->
  <div id="sb-step-lang" class="p-6 border-b border-neutral-100">
    <div class="text-xs font-bold text-neutral-400 uppercase tracking-widest mb-3">
      {t.langLabel}
    </div>
    <div class="flex gap-3 flex-wrap" id="sb-langs">
      {ALL_LANGS.map(code => (
        <button
          type="button"
          data-lang={code}
          aria-label={LANG_META[code].label}
          title={LANG_META[code].label}
          class:list={[
            "lang-btn w-12 h-12 rounded-full border-2 text-2xl flex items-center justify-center transition-all duration-150",
            code === defaultLang
              ? "border-yellow-400 ring-2 ring-yellow-300 scale-110"
              : "border-neutral-200 hover:border-yellow-300 hover:scale-105"
          ]}
        >
          {LANG_META[code].flag}
        </button>
      ))}
    </div>
  </div>

  <!-- PASO 3: TOURS (sin botón intermedio) -->
  <div id="sb-step-tours" class="p-6">
    <div class="text-xs font-bold text-neutral-400 uppercase tracking-widest mb-3">
      {t.toursLabel}
    </div>
    <div id="sb-results" class="flex flex-col gap-2">
      <!-- inyectado por JS -->
    </div>
    <div id="sb-empty" class="hidden text-sm text-neutral-400 text-center py-4">
      {t.noTours}
    </div>
    <div id="sb-placeholder" class="text-sm text-neutral-300 text-center py-4 italic">
      ↑ Selecciona un idioma para ver los tours
    </div>
  </div>

</div>

<script define:vars={{ tours, lang, defaultLang, TEXTS_JSON: JSON.stringify(TEXTS) }}>
(function() {
  const t = JSON.parse(TEXTS_JSON)[lang] || JSON.parse(TEXTS_JSON).es;

  const cityBtns   = document.querySelectorAll(".city-btn");
  const langBtns   = document.querySelectorAll(".lang-btn");
  const results    = document.getElementById("sb-results");
  const empty      = document.getElementById("sb-empty");
  const placeholder = document.getElementById("sb-placeholder");
  const stepTours  = document.getElementById("sb-step-tours");

  let selectedCity = "brussels";
  let selectedLang = defaultLang;

  // Orden: free primero
  const kindRank = k => k === "free" ? 0 : k === "special" ? 1 : 2;

  function renderTours() {
    results.innerHTML = "";
    empty.classList.add("hidden");
    placeholder.classList.add("hidden");

    if (!selectedLang) {
      placeholder.classList.remove("hidden");
      return;
    }

    const filtered = (tours || [])
      .filter(t => t.city === selectedCity && t.tourLang === selectedLang)
      .sort((a, b) => kindRank(a.kind) - kindRank(b.kind));

    if (!filtered.length) {
      empty.classList.remove("hidden");
      return;
    }

    filtered.forEach(tour => {
      const card = document.createElement("a");
      card.href = tour.url;
      card.className = "flex items-center justify-between gap-3 px-4 py-3.5 rounded-xl border-2 border-neutral-200 bg-white hover:border-yellow-400 hover:bg-yellow-50 transition-all duration-150 group cursor-pointer no-underline";

      const kindLabel = t.kinds?.[tour.kind] || tour.kind;
      const kindColor = tour.kind === "free"
        ? "bg-yellow-100 text-yellow-800"
        : tour.kind === "private"
        ? "bg-neutral-100 text-neutral-700"
        : "bg-orange-100 text-orange-800";

      const priceText = tour.kind === "free"
        ? `<span class="text-green-600 font-semibold text-sm">${t.free}</span>`
        : `<span class="font-semibold text-neutral-900 text-sm">${tour.price}</span>`;

      card.innerHTML = `
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-2 mb-1">
            <span class="text-xs font-bold px-2 py-0.5 rounded-full ${kindColor}">${kindLabel}</span>
          </div>
          <div class="font-semibold text-neutral-900 text-sm leading-tight">${tour.name}</div>
          <div class="text-xs text-neutral-400 mt-0.5">${tour.duration}</div>
        </div>
        <div class="flex items-center gap-2 flex-shrink-0">
          ${priceText}
          <svg class="w-4 h-4 text-neutral-300 group-hover:text-yellow-500 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path d="M9 18l6-6-6-6"/>
          </svg>
        </div>
      `;

      results.appendChild(card);
    });

    // Scroll suave a los tours
    setTimeout(() => {
      stepTours.scrollIntoView({ behavior: "smooth", block: "nearest" });
    }, 100);
  }

  // Ciudad
  cityBtns.forEach(btn => {
    btn.addEventListener("click", () => {
      if (btn.disabled) return;
      selectedCity = btn.dataset.city;

      cityBtns.forEach(b => {
        b.classList.remove("border-yellow-400", "bg-yellow-50");
        b.classList.add("border-neutral-200", "bg-white");
      });
      btn.classList.add("border-yellow-400", "bg-yellow-50");
      btn.classList.remove("border-neutral-200", "bg-white");

      renderTours();

      // Scroll al selector de idioma
      document.getElementById("sb-step-lang")?.scrollIntoView({ behavior: "smooth", block: "nearest" });
    });
  });

  // Idioma
  langBtns.forEach(btn => {
    btn.addEventListener("click", () => {
      selectedLang = btn.dataset.lang;

      langBtns.forEach(b => {
        b.classList.remove("border-yellow-400", "ring-2", "ring-yellow-300", "scale-110");
        b.classList.add("border-neutral-200");
      });
      btn.classList.add("border-yellow-400", "ring-2", "ring-yellow-300", "scale-110");
      btn.classList.remove("border-neutral-200");

      renderTours();
    });
  });

  // Init — si ya hay idioma preseleccionado renderizar
  if (selectedLang) renderTours();
})();
</script>
