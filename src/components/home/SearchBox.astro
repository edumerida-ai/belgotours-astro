---
interface Tour {
  name: string;
  duration: string;
  price: string;
  tourLang: "es" | "en" | "it" | "fr";
  city: "brussels" | "bruges" | "antwerp" | "leuven";
  kind: "free" | "private" | "special";
  url: string;
}

interface Props {
  lang: "es" | "en" | "it" | "fr" | "pt";
  title: string;
  subtitle: string;
  tours?: Tour[];
  ctaLabel: string;
}

const { lang, title, subtitle, tours = [], ctaLabel } = Astro.props;

/* =========================
   TEXTOS POR IDIOMA (sin emojis)
========================= */
const TEXTS = {
  es: {
    cityLabel: "1. Ciudad",
    cityPlaceholder: "Selecciona una ciudad",
    langLabel: "2. Idioma",
    chooseTourLabel: "3. Tours disponibles",
    empty: "No hay tours disponibles para este idioma.",
    trust: ["Pago libre", "Confirmación inmediata", "Cancelación fácil"],
    ctaHelper: "Elige un tour para continuar",
    cities: {
      brussels: "Bruselas",
      bruges: "Brujas",
      antwerp: "Amberes",
      leuven: "Lovaina",
    },
  },
  en: {
    cityLabel: "1. City",
    cityPlaceholder: "Select a city",
    langLabel: "2. Language",
    chooseTourLabel: "3. Available tours",
    empty: "No tours available for this language.",
    trust: ["Tip-based", "Instant confirmation", "Easy cancellation"],
    ctaHelper: "Choose a tour to continue",
    cities: {
      brussels: "Brussels",
      bruges: "Bruges",
      antwerp: "Antwerp",
      leuven: "Leuven",
    },
  },
  it: {
    cityLabel: "1. Città",
    cityPlaceholder: "Seleziona una città",
    langLabel: "2. Lingua",
    chooseTourLabel: "3. Tour disponibili",
    empty: "Nessun tour disponibile per questa lingua.",
    trust: ["Prezzo libero", "Conferma immediata", "Cancellazione facile"],
    ctaHelper: "Scegli un tour per continuare",
    cities: {
      brussels: "Bruxelles",
      bruges: "Bruges",
      antwerp: "Anversa",
      leuven: "Lovanio",
    },
  },
  fr: {
    cityLabel: "1. Ville",
    cityPlaceholder: "Sélectionnez une ville",
    langLabel: "2. Langue",
    chooseTourLabel: "3. Tours disponibles",
    empty: "Aucun tour disponible pour cette langue.",
    trust: ["Contribution libre", "Confirmation immédiate", "Annulation facile"],
    ctaHelper: "Choisissez un tour pour continuer",
    cities: {
      brussels: "Bruxelles",
      bruges: "Bruges",
      antwerp: "Anvers",
      leuven: "Louvain",
    },
  },
  pt: {
    cityLabel: "1. Cidade",
    cityPlaceholder: "Selecione uma cidade",
    langLabel: "2. Idioma",
    chooseTourLabel: "3. Tours disponíveis",
    empty: "Não há tours disponíveis para este idioma.",
    trust: ["Contribuição livre", "Confirmação imediata", "Cancelamento fácil"],
    ctaHelper: "Escolha um tour para continuar",
    cities: {
      brussels: "Bruxelas",
      bruges: "Bruges",
      antwerp: "Antuérpia",
      leuven: "Lovaina",
    },
  },
};
const t = TEXTS[lang] ?? TEXTS.es;

const LANG_META: Record<string, { label: string; flag: string }> = {
  es: { label: "Español", flag: "🇪🇸" },
  en: { label: "English", flag: "🇬🇧" },
  it: { label: "Italiano", flag: "🇮🇹" },
  fr: { label: "Français", flag: "🇫🇷" },
};

const ALL_LANGS: Array<"es" | "en" | "it" | "fr"> = ["es", "en", "it", "fr"];
const ALL_CITIES: Array<"brussels" | "bruges" | "antwerp" | "leuven"> = ["brussels", "bruges", "antwerp", "leuven"];

const uid = `sb-${Math.random().toString(36).slice(2)}`;
---

<div
  data-searchbox-card
  class="max-w-5xl mx-auto bg-white rounded-3xl border border-neutral-200 shadow-xl p-5 md:p-7 mt-6 lg:mt-10 relative z-[70]"
>
  <section class="relative" data-searchbox={uid}>
    <header class="text-center mb-5">
      <h3 class="text-2xl md:text-3xl font-bold text-neutral-900">{title}</h3>
      <p class="text-neutral-600 mt-1">{subtitle}</p>
    </header>

    <!-- CONTROLES -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-4 lg:gap-6 items-end">
      
      <!-- CIUDAD (Custom Select Minimalista) -->
<div class="lg:col-span-4 relative" data-city-wrapper>
  <label class="block text-sm font-medium text-neutral-700 mb-2">
    {t.cityLabel}
  </label>

  <!-- Trigger -->
  <button
    type="button"
    data-city-trigger
    class="w-full h-[52px] px-4 flex items-center justify-between rounded-xl border border-neutral-300 bg-white text-neutral-900 hover:border-neutral-400 transition focus:outline-none focus:ring-2 focus:ring-yellow-300"
  >
    <span data-city-label>{t.cities.brussels}</span>
    <svg class="w-4 h-4 text-neutral-500 transition-transform duration-200" data-city-chevron fill="none" viewBox="0 0 24 24">
      <path d="M19 9l-7 7-7-7" stroke="currentColor" stroke-width="2" />
    </svg>
  </button>

  <!-- Dropdown -->
  <div
    data-city-dropdown
    class="absolute left-0 right-0 mt-2 bg-white border border-neutral-200 rounded-xl shadow-xl opacity-0 pointer-events-none transition z-50 max-h-60 overflow-y-auto"
  >
    {ALL_CITIES.map(city => {
      const isFuture = city === "antwerp" || city === "leuven";
      return (
        <button
          type="button"
          data-city-option={city}
          disabled={isFuture}
          class="w-full text-left px-4 py-3 text-sm text-neutral-800 hover:bg-yellow-50 hover:text-neutral-900 transition disabled:opacity-40 disabled:cursor-not-allowed"
        >
          {t.cities[city]}
        </button>
      );
    })}
  </div>

      </div>

      <!-- IDIOMA (VISIBLE, SIN DROPDOWN) -->
      <div class="lg:col-span-5">
        <label class="block text-sm font-medium text-neutral-700 mb-2">
          {t.langLabel}
        </label>

        <div class="flex items-center gap-3 flex-wrap">
          {ALL_LANGS.map(code => (
            <button
              type="button"
              class="lang-pill w-11 h-11 rounded-full border border-neutral-300 bg-white hover:border-yellow-400 transition flex items-center justify-center text-2xl"
              data-lang={code}
              aria-label={LANG_META[code].label}
              title={LANG_META[code].label}
            >
              {LANG_META[code].flag}
            </button>
          ))}
        </div>
      </div>

      <!-- CTA -->
      <div class="lg:col-span-3">
        <button
          data-search-button
          disabled
          class="w-full h-[52px] rounded-xl bg-yellow-400 text-black font-semibold hover:bg-yellow-300 transition disabled:opacity-40"
        >
          {ctaLabel}
        </button>

        <div data-cta-helper class="text-xs text-neutral-500 mt-2">
          {t.ctaHelper}
        </div>
      </div>
    </div>

    <!-- RESULTADOS -->
    <div class="mt-6">
      <div class="text-sm font-semibold text-neutral-900 mb-3">
        {t.chooseTourLabel}
      </div>

      <div
        data-results
        class="grid grid-cols-1 md:grid-cols-2 gap-3"
      >
        <!-- inyectado por JS -->
      </div>

      <div data-empty class="hidden text-sm text-neutral-600 mt-3">
        {t.empty}
      </div>
    </div>

    <!-- MICRO CONFIANZA (sin checkmarks) -->
    <div class="flex flex-wrap justify-center gap-6 text-xs text-neutral-500 mt-6">
      {t.trust.map(item => <span>{item}</span>)}
    </div>
  </section>
</div>

<script define:vars={{ tours, uid, lang }}>
  const root = document.querySelector(`[data-searchbox="${uid}"]`);
  if (!root) return;

  const card = document.querySelector("[data-searchbox-card]");
  
  const pills = root.querySelectorAll(".lang-pill");
  const results = root.querySelector("[data-results]");
  const empty = root.querySelector("[data-empty]");
  const button = root.querySelector("[data-search-button]");
  const helper = root.querySelector("[data-cta-helper]");
  const cityWrapper = root.querySelector("[data-city-wrapper]");
const cityTrigger = root.querySelector("[data-city-trigger]");
const cityDropdown = root.querySelector("[data-city-dropdown]");
const cityLabel = root.querySelector("[data-city-label]");
const cityChevron = root.querySelector("[data-city-chevron]");
const cityOptions = root.querySelectorAll("[data-city-option]");

  // defaults
  const DEFAULT_CITY = "brussels";
  const defaultLang = (["es","en","it","fr"].includes(lang) ? lang : null);

  let selectedCity = "brussels";
  let selectedLang = defaultLang; // si vienes de /en/ lo preselecciona
  let selectedTourUrl = null;

  // UI: marcar idioma activo
  const paintLang = () => {
    pills.forEach((p) => {
      const isActive = p.dataset.lang === selectedLang;
      p.classList.toggle("ring-2", isActive);
      p.classList.toggle("ring-yellow-400", isActive);
      p.classList.toggle("border-yellow-400", isActive);
    });
  };

  // orden recomendado: free -> special -> private
  const kindRank = (k) => (k === "free" ? 0 : k === "special" ? 1 : 2);

  const render = () => {
    results.innerHTML = "";
    selectedTourUrl = null;
    button.disabled = true;

    // si no hay idioma aún, no renderices
    if (!selectedLang) {
      empty.classList.add("hidden");
      helper.textContent = "Selecciona un idioma para ver los tours disponibles.";
      return;
    }

    const filtered = (tours || [])
      .filter((t) => t.city === selectedCity && t.tourLang === selectedLang)
      .sort((a, b) => kindRank(a.kind) - kindRank(b.kind));

    if (!filtered.length) {
      empty.classList.remove("hidden");
      helper.textContent = "Prueba otra ciudad o idioma.";
      return;
    }

    empty.classList.add("hidden");
    helper.textContent = "Elige un tour para continuar.";

    filtered.forEach((tour) => {
      const item = document.createElement("button");
      item.type = "button";
      item.className =
        "text-left p-4 rounded-2xl border border-neutral-200 bg-white hover:border-yellow-300 hover:shadow-sm transition";

      // badge simple sin emojis
      let badge = "Experiencia";
      let badgeClass = "bg-amber-100 text-amber-900";
      if (tour.kind === "free") { badge = "Free tour"; badgeClass = "bg-yellow-100 text-yellow-900"; }
      if (tour.kind === "private") { badge = "Tour privado"; badgeClass = "bg-neutral-100 text-neutral-900"; }
      if (tour.kind === "special") { badge = "Tour especial"; badgeClass = "bg-orange-100 text-orange-900"; }

      item.innerHTML = `
        <div class="inline-flex text-xs font-semibold px-2 py-1 rounded ${badgeClass}">
          ${badge}
        </div>
        <div class="mt-2 font-semibold text-neutral-900 text-sm">
          ${tour.name}
        </div>
        <div class="text-xs text-neutral-600 mt-1">
          ${tour.duration} · ${tour.price}
        </div>
      `;

      item.addEventListener("click", () => {
        // limpiar selección previa
        results.querySelectorAll("[data-active='1']").forEach((n) => {
          n.removeAttribute("data-active");
          n.classList.remove("ring-2", "ring-yellow-400");
        });

        item.setAttribute("data-active", "1");
        item.classList.add("ring-2", "ring-yellow-400");

        selectedTourUrl = tour.url;
        button.disabled = false;

        // asegurar que el CTA quede visible
        card?.scrollIntoView({ behavior: "smooth", block: "center" });
      });

      results.appendChild(item);
    });
  };

  // events
  

  pills.forEach((pill) => {
    pill.addEventListener("click", () => {
      selectedLang = pill.dataset.lang;
      paintLang();
      render();
    });
  });

  // CTA
  button.addEventListener("click", () => {
    if (selectedTourUrl) window.location.href = selectedTourUrl;
  });


  const closeCityDropdown = () => {
  cityDropdown.classList.add("opacity-0", "pointer-events-none");
  cityChevron.classList.remove("rotate-180");
};

const openCityDropdown = () => {
  cityDropdown.classList.remove("opacity-0", "pointer-events-none");
  cityChevron.classList.add("rotate-180");
};

cityTrigger?.addEventListener("click", () => {
  const isClosed = cityDropdown.classList.contains("opacity-0");
  if (isClosed) openCityDropdown();
  else closeCityDropdown();
});

cityOptions.forEach((btn) => {
  btn.addEventListener("click", () => {
    if (btn.disabled) return;

    selectedCity = btn.dataset.cityOption;
    cityLabel.textContent = btn.textContent;
    closeCityDropdown();
    render();
  });
});

document.addEventListener("click", (e) => {
  if (!cityWrapper.contains(e.target)) {
    closeCityDropdown();
  }
});

  // init
  if (citySelect) citySelect.value = DEFAULT_CITY;
  paintLang();
  render();
</script>