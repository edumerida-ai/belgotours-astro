---
import type { AppUser } from '../../../lib/app/types';
interface Props { user: AppUser; }
const { user } = Astro.props;
const now = new Date().toLocaleDateString('es-ES', {
  weekday: 'long', day: 'numeric', month: 'long', year: 'numeric'
});
---

<header class="app-header">
  <span class="header-date">{now}</span>
  <div class="header-user">
    <span class="user-name">{user.username}</span>
    <span class="user-email">{user.email}</span>
  </div>
</header>

<style>
  .app-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 0.875rem 2rem; background: #fff;
    border-bottom: 1px solid #e5e7eb; flex-shrink: 0;
  }
  .header-date { font-size: 0.8rem; color: #9ca3af; text-transform: capitalize; }
  .header-user { display: flex; flex-direction: column; align-items: flex-end; gap: 0.1rem; }
  .user-name { font-size: 0.875rem; font-weight: 600; color: #111827; }
  .user-email { font-size: 0.75rem; color: #9ca3af; }
</style>
